generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Committee {
  id            String            @id @default(cuid())
  name          String
  description   String?
  logo          String?
  shortCode     String?
  establishedDate DateTime?
  registrationNo String?
  address       String?
  email         String?
  contactNo     String?
  website       String?

  // Bank Details
  bankName          String?
  accountNumber     String?
  accountHolderName String?
  branch            String?
  defaultCurrency   String? @default("LKR")

  status        Status            @default(ACTIVE)
  mainMahallaId String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  mainMahalla   MainMahalla       @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  terms         CommitteeTerm[]
  users         User[]
  donations     Donation[]
}

enum FinancialStatus {
  PENDING
  APPROVED
}

model CommitteeTerm {
  id                  String               @id @default(cuid())
  name                String               // e.g., "Term 2024-2025"
  startDate           DateTime?
  endDate             DateTime?
  status              Status               @default(ACTIVE)
  financialsStatus    FinancialStatus      @default(PENDING)
  financialsApprovedAt DateTime?
  committeeId         String
  committee           Committee            @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  members             CommitteeMember[]
  balances            CommitteeTermBalance[]
  donations           Donation[]
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model CommitteeMember {
  id                 String       @id @default(cuid())
  role               String
  status             Status       @default(ACTIVE)
  activeDateFrom     DateTime?
  activeDateTo       DateTime?
  committeeTermId    String
  committeeTerm      CommitteeTerm @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  familyMemberId     String
  familyMember       FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  hasDashboardAccess Boolean      @default(false)
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([committeeTermId, familyMemberId])
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role         @default(MEMBER)
  mainMahallaId String?
  subMahallaId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  committeeId   String?
  committee     Committee?   @relation(fields: [committeeId], references: [id])
  mainMahalla   MainMahalla? @relation(fields: [mainMahallaId], references: [id])
  subMahalla    SubMahalla?  @relation(fields: [subMahallaId], references: [id])
}

model RegistrationRequest {
  id              String             @id @default(cuid())
  licensePlan     String
  fullName        String
  email           String             @unique
  phone           String?
  mahallaName     String
  selfieUrl       String?
  governmentIdUrl String?
  status          RegistrationStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model MainMahalla {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  logo                    String?
  coverImage              String?
  registeredDate          DateTime                 @default(now())
  email                   String?
  address                 String?
  country                 String?
  province                String?
  district                String?
  area                    String?
  defaultCurrency         String                   @default("LKR")
  activatedDate           DateTime?
  deactivatedDate         DateTime?
  status                  Status                   @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  committees              Committee[]
  subMahallas             SubMahalla[]
  users                   User[]
  openingBalanceCategories OpeningBalanceCategory[]
  donations               Donation[]
  donors                  Donor[]
}

model OpeningBalanceCategory {
  id            String                 @id @default(cuid())
  name          String
  mainMahallaId String
  mainMahalla   MainMahalla            @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  balances      CommitteeTermBalance[]
  createdAt     DateTime               @default(now())

  @@unique([mainMahallaId, name])
}

model CommitteeTermBalance {
  id                String                 @id @default(cuid())
  amount            Float                  @default(0)
  committeeTermId   String
  committeeTerm     CommitteeTerm          @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  categoryId        String
  category          OpeningBalanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([committeeTermId, categoryId])
}

model SubMahalla {
  id             String       @id @default(cuid())
  name           String       @unique
  logo           String?
  coverImage     String?
  registeredDate DateTime     @default(now())
  email          String?
  address        String?
  area           String?
  mainMahallaId  String
  status         Status       @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  familyCards    FamilyCard[]
  mainMahalla    MainMahalla  @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  users          User[]
}

model FamilyCard {
  id                String         @id @default(cuid())
  mainMahallaCardNo String?
  subMahallaCardNo  String?
  registeredDate    DateTime       @default(now())
  livingType        LivingType
  livingFromDate    DateTime?
  attachments       String[]
  status            Status         @default(ACTIVE)
  subMahallaId      String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subMahalla        SubMahalla     @relation(fields: [subMahallaId], references: [id], onDelete: Cascade)
  members           FamilyMember[]
}

model FamilyMember {
  id               String            @id @default(cuid())
  title            String
  fullName         String
  dob              DateTime
  nic              String?           @unique
  relationship     String
  isBreadwinner    Boolean           @default(false)
  isStudent        Boolean           @default(false)
  school           String?
  grade            String?
  occupation       String?
  monthlyEarnings  Float?
  maritalStatus    String?
  dateOfDemise     DateTime?
  attachments      String[]
  status           Status            @default(ACTIVE)
  familyCardId     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  email            String?           @unique
  committeeMembers CommitteeMember[]
  familyCard       FamilyCard        @relation(fields: [familyCardId], references: [id], onDelete: Cascade)
  donors           Donor[]
}

model MasterCountry {
  id                    String           @id @default(cuid())
  name                  String           @unique
  code                  String
  currency              String
  currencyDecimalPlaces Int              @default(2)
  provinces             MasterProvince[]
}

model MasterProvince {
  id        String           @id @default(cuid())
  name      String
  countryId String
  districts MasterDistrict[]
  country   MasterCountry    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
}

model MasterDistrict {
  id         String         @id @default(cuid())
  name       String
  provinceId String
  areas      MasterArea[]
  province   MasterProvince @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  @@unique([name, provinceId])
}

model MasterArea {
  id         String         @id @default(cuid())
  name       String
  districtId String
  district   MasterDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([name, districtId])
}

model MasterSchool {
  id   String @id @default(cuid())
  name String @unique
}

model MasterGrade {
  id   String @id @default(cuid())
  name String @unique
}

model MasterOccupation {
  id   String @id @default(cuid())
  name String @unique
}

enum DonorType {
  INTERNAL
  EXTERNAL
}

model Donor {
  id             String         @id @default(cuid())
  type           DonorType      @default(INTERNAL)
  name           String         // Display name
  phone          String?
  email          String?
  familyMemberId String?
  mainMahallaId  String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  donations      Donation[]
  contacts       DonorContact[]
  familyMember   FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)
  mainMahalla    MainMahalla    @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)

  @@index([mainMahallaId])
}

model DonorContact {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  whatsapp   String?
  email      String?
  donorId    String
  donor      Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Donation {
  id              String         @id @default(cuid())
  amount          Float
  date            DateTime       @default(now())
  paymentMethod   String         // e.g., CASH, BANK, CHEQUE, PDC
  reference       String?        // e.g., Cheque No, Bank Ref
  attachmentUrl   String?
  
  // Relations
  donorId         String
  donor           Donor          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  
  committeeId     String
  committee       Committee      @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  
  committeeTermId String
  committeeTerm   CommitteeTerm  @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  
  mainMahallaId   String
  mainMahalla     MainMahalla    @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([donorId])
  @@index([committeeId])
  @@index([committeeTermId])
}

enum Role {
  PLATFORM_ADMIN
  MAIN_ADMIN
  SUB_ADMIN
  MEMBER
  COMMITTEE_ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LivingType {
  OWN_HOUSE
  RENTED
  MONTHLY_SUBSCRIPTION_MAIN
  MONTHLY_SUBSCRIPTION_SUB
}

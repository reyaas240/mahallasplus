generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Committee {
  id            String            @id @default(cuid())
  name          String
  description   String?
  logo          String?
  shortCode     String?
  establishedDate DateTime?
  registrationNo String?
  address       String?
  email         String?
  contactNo     String?
  website       String?

  // Bank Details
  bankName          String?
  accountNumber     String?
  accountHolderName String?
  branch            String?
  defaultCurrency   String? @default("LKR")

  status        Status            @default(ACTIVE)
  allowMainMahallaView Boolean         @default(false)
  mainMahallaId String
  subMahallaId  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  mainMahalla   MainMahalla       @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  subMahalla    SubMahalla?       @relation(fields: [subMahallaId], references: [id], onDelete: Cascade)
  terms         CommitteeTerm[]
  users         User[]
  donations     Donation[]
  fundRequests  FundRequest[]
  requestCategories RequestCategory[]
  projectMasters    ProjectMaster[]
}

enum FinancialStatus {
  PENDING
  APPROVED
}

model CommitteeTerm {
  id                  String               @id @default(cuid())
  name                String               // e.g., "Term 2024-2025"
  startDate           DateTime?
  endDate             DateTime?
  status              Status               @default(ACTIVE)
  financialsStatus    FinancialStatus      @default(PENDING)
  financialsApprovedAt DateTime?
  committeeId         String
  committee           Committee            @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  members             CommitteeMember[]
  balances            CommitteeTermBalance[]
  donations           Donation[]
  fundRequests        FundRequest[]
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model CommitteeMember {
  id                 String       @id @default(cuid())
  role               String
  status             Status       @default(ACTIVE)
  activeDateFrom     DateTime?
  activeDateTo       DateTime?
  committeeTermId    String
  committeeTerm      CommitteeTerm @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  familyMemberId     String
  familyMember       FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  hasDashboardAccess Boolean      @default(false)
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([committeeTermId, familyMemberId])
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role         @default(MEMBER)
  mainMahallaId String?
  subMahallaId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  committeeId   String?
  committee     Committee?   @relation(fields: [committeeId], references: [id])
  mainMahalla   MainMahalla? @relation(fields: [mainMahallaId], references: [id])
  subMahalla    SubMahalla?  @relation(fields: [subMahallaId], references: [id])
  notices       Notice[]
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model RegistrationRequest {
  id              String             @id @default(cuid())
  licensePlanId   String?
  licensePlan     LicensePlan?       @relation(fields: [licensePlanId], references: [id])
  fullName        String
  email           String             @unique
  phone           String?
  mahallaName     String
  country         String?
  province        String?
  district        String?
  divisionalSecretariat String?
  city            String?
  address         String?
  selfieUrl       String?
  governmentIdUrl String?
  isVerified      Boolean            @default(false)
  status          RegistrationStatus @default(PENDING)
  termsAccepted   Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model MainMahalla {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  logo                    String?
  coverImage              String?
  registeredDate          DateTime                 @default(now())
  email                   String?
  address                 String?
  country                 String?
  province                String?
  district                String?
  divisionalSecretariat   String?
  area                    String?
  phone                   String?
  defaultCurrency         String                   @default("LKR")
  activatedDate           DateTime?
  deactivatedDate         DateTime?
  status                  Status                   @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  licensePlanId           String?
  licensePlan             LicensePlan?             @relation(fields: [licensePlanId], references: [id])
  subscription            Subscription?
  committees              Committee[]
  subMahallas             SubMahalla[]
  users                   User[]
  openingBalanceCategories OpeningBalanceCategory[]
  donations               Donation[]
  donors                  Donor[]
  notices                 Notice[]
}

model OpeningBalanceCategory {
  id            String                 @id @default(cuid())
  name          String
  mainMahallaId String
  mainMahalla   MainMahalla            @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  balances      CommitteeTermBalance[]
  createdAt     DateTime               @default(now())

  @@unique([mainMahallaId, name])
}

model CommitteeTermBalance {
  id                String                 @id @default(cuid())
  amount            Float                  @default(0)
  committeeTermId   String
  committeeTerm     CommitteeTerm          @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  categoryId        String
  category          OpeningBalanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([committeeTermId, categoryId])
}

model SubMahalla {
  id             String       @id @default(cuid())
  name           String       @unique
  logo           String?
  coverImage     String?
  registeredDate DateTime     @default(now())
  email          String?
  address        String?
  area           String?
  mainMahallaId  String
  status         Status       @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  familyCards    FamilyCard[]
  committees     Committee[]
  mainMahalla    MainMahalla  @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  users          User[]
  donors         Donor[]
  notices        Notice[]
}

model FamilyCard {
  id                String         @id @default(cuid())
  mainMahallaCardNo String?
  subMahallaCardNo  String?
  registeredDate    DateTime       @default(now())
  livingType        LivingType
  livingFromDate    DateTime?
  address           String?
  latitude          Float?
  longitude         Float?
  attachments       String[]
  status            Status         @default(ACTIVE)
  subMahallaId      String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subMahalla        SubMahalla     @relation(fields: [subMahallaId], references: [id], onDelete: Cascade)
  members           FamilyMember[]
}

model FamilyMember {
  id               String            @id @default(cuid())
  title            String
  fullName         String
  dob              DateTime?
  gender           String?
  nic              String?           @unique
  relationship     String
  isBreadwinner    Boolean           @default(false)
  isStudent        Boolean           @default(false)
  school           String?
  grade            String?
  occupation       String?
  monthlyEarnings  Float?
  maritalStatus    String?
  dateOfDemise     DateTime?
  attachments      String[]
  status           Status            @default(ACTIVE)
  familyCardId     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  email            String?           @unique
  phone            String?
  committeeMembers CommitteeMember[]
  familyCard       FamilyCard        @relation(fields: [familyCardId], references: [id], onDelete: Cascade)
  donors           Donor[]
  fundRequests     FundRequest[]
}

model MasterCountry {
  id                    String           @id @default(cuid())
  name                  String           @unique
  code                  String
  currency              String
  currencyDecimalPlaces Int              @default(2)
  provinces             MasterProvince[]
}

model MasterProvince {
  id        String           @id @default(cuid())
  name      String
  countryId String
  districts MasterDistrict[]
  country   MasterCountry    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
}

model MasterDistrict {
  id                     String                        @id @default(cuid())
  name                   String
  provinceId             String
  divisionalSecretariats MasterDivisionalSecretariat[]
  province               MasterProvince                @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  @@unique([name, provinceId])
}

model MasterDivisionalSecretariat {
  id         String         @id @default(cuid())
  name       String
  districtId String
  district   MasterDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  areas      MasterArea[]

  @@unique([name, districtId])
}

model MasterArea {
  id                      String                      @id @default(cuid())
  name                    String
  divisionalSecretariatId String
  divisionalSecretariat   MasterDivisionalSecretariat @relation(fields: [divisionalSecretariatId], references: [id], onDelete: Cascade)
  subAreas                MasterSubArea[]

  @@unique([name, divisionalSecretariatId])
}

model MasterSubArea {
  id        String     @id @default(cuid())
  name      String
  areaId    String
  area      MasterArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MasterSchool {
  id   String @id @default(cuid())
  name String @unique
}

model MasterGrade {
  id   String @id @default(cuid())
  name String @unique
}

model MasterOccupation {
  id   String @id @default(cuid())
  name String @unique
}

model MasterTitle {
  id   String @id @default(cuid())
  name String @unique
}

model RequestCategory {
  id          String    @id @default(cuid())
  name        String
  committeeId String
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([committeeId, name])
}

model ProjectMaster {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  committeeId String
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  donations   Donation[]
  fundRequests FundRequest[]

  @@unique([committeeId, name])
}

enum DonorType {
  INTERNAL
  EXTERNAL
}

model Donor {
  id             String         @id @default(cuid())
  type           DonorType      @default(INTERNAL)
  name           String         // Display name
  phone          String?
  email          String?
  familyMemberId String?
  mainMahallaId  String
  subMahallaId   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  donations      Donation[]
  contacts       DonorContact[]
  familyMember   FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)
  mainMahalla    MainMahalla    @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  subMahalla     SubMahalla?    @relation(fields: [subMahallaId], references: [id], onDelete: Cascade)

  @@index([mainMahallaId])
  @@index([subMahallaId])
}

model DonorContact {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  whatsapp   String?
  email      String?
  donorId    String
  donor      Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Donation {
  id              String         @id @default(cuid())
  amount          Float
  date            DateTime       @default(now())
  paymentMethod   String         // e.g., CASH, BANK, CHEQUE, PDC
  reference       String?        // e.g., Cheque No, Bank Ref
  attachmentUrl   String?
  
  // Relations
  donorId         String
  donor           Donor          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  
  committeeId     String
  committee       Committee      @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  
  committeeTermId String
  committeeTerm   CommitteeTerm  @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  
  mainMahallaId   String
  mainMahalla     MainMahalla    @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  
  projectId       String?
  project         ProjectMaster? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([donorId])
  @@index([committeeId])
  @@index([committeeTermId])
}

enum Role {
  PLATFORM_ADMIN
  MAIN_ADMIN
  MAIN_STAFF
  SUB_ADMIN
  MEMBER
  COMMITTEE_ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LivingType {
  OWN_HOUSE
  RENTED
  MONTHLY_SUBSCRIPTION_MAIN
  MONTHLY_SUBSCRIPTION_SUB
}

// ───────────────── Fund Distribution ─────────────────

enum FundRequestStatus {
  RECEIVED
  UNDER_VERIFICATION
  UNDER_DISCUSSION
  UNDER_INVESTIGATION
  INQUIRY_SCHEDULED
  APPROVED
  REJECTED
  ON_HOLD
  ON_GOING
  DISBURSED
}

enum BeneficiaryType {
  INTERNAL
  EXTERNAL
}

enum DisbursementMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
}

enum PaymentType {
  ONE_TIME
  MONTHLY
}

model FundRequest {
  id                String             @id @default(cuid())

  // Context
  committeeId       String
  committee         Committee          @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  committeeTermId   String
  committeeTerm     CommitteeTerm      @relation(fields: [committeeTermId], references: [id], onDelete: Cascade)
  projectId         String?
  project           ProjectMaster?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName       String?

  // Beneficiary
  beneficiaryType   BeneficiaryType
  familyMemberId    String?
  familyMember      FamilyMember?      @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)
  externalName      String?
  externalPhone     String?
  externalAddress   String?

  // Request Details
  purpose           String
  description       String?
  requestedAmount   Float?
  letterRefNo       String?
  attachments       String[]           @default([])

  // Verification (Internal only)
  verified          Boolean            @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?

  // Decision
  grantedAmount     Float?
  paymentType       PaymentType        @default(ONE_TIME)
  durationMonths    Int?
  startMonth        String?            // YYYY-MM
  endMonth          String?            // YYYY-MM
  status            FundRequestStatus  @default(RECEIVED)
  decisionNotes     String?

  // Disbursement
  totalDisbursed    Float              @default(0)
  disbursements     FundDisbursement[]

  // Children
  investigations    Investigation[]
  appointments      FundAppointment[]
  quotations        FundQuotation[]
  events            FundRequestEvent[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([committeeId])
  @@index([committeeTermId])
}

model FundDisbursement {
  id                String             @id @default(cuid())
  fundRequestId     String
  fundRequest       FundRequest        @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)
  
  amount            Float
  method            DisbursementMethod
  chequeNumber      String?
  bankReference     String?
  handedOverDate    DateTime
  assignedMembers   String?
  attachments       String[]           @default([])
  
  createdAt         DateTime           @default(now())
  
  @@index([fundRequestId])
}

model Investigation {
  id              String       @id @default(cuid())
  fundRequestId   String
  fundRequest     FundRequest  @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)

  investigators   String       // Assigned group
  visitDate       DateTime     // Planned/Assigned date
  findings        String
  actualVisitDate DateTime?    // When it actually happened
  attendedMembers String?      // Who actually went
  attachments     String[]     @default([])

  createdAt       DateTime     @default(now())
}

model FundAppointment {
  id              String       @id @default(cuid())
  fundRequestId   String
  fundRequest     FundRequest  @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)

  scheduledDate   DateTime
  location        String?
  purpose         String?
  outcome         String?
  attended        Boolean      @default(false)

  createdAt       DateTime     @default(now())
}

model FundQuotation {
  id              String       @id @default(cuid())
  fundRequestId   String
  fundRequest     FundRequest  @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)

  vendor          String
  amount          Float
  description     String?
  attachments     String[]
  isGranted       Boolean      @default(false)

  createdAt       DateTime     @default(now())
}

model FundRequestEvent {
  id              String       @id @default(cuid())
  fundRequestId   String
  fundRequest     FundRequest  @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)

  action          String
  performedBy     String
  note            String?

  createdAt       DateTime     @default(now())
}

model SystemSettings {
  id              String   @id @default("global")
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String?
  smtpFromEmail   String?
  smtpFromName    String?
  smtpEncryption  String?  // SSL or TLS
  recaptchaSiteKey  String?
  recaptchaSecretKey String?
  
  // Payment Details
  bankName          String?
  accountHolder     String?
  accountNumber     String?
  bankInstructions  String?
  
  // Branding
  logoUrl           String?
  
  // Feature Toggles
  whatsappBroadcastsEnabled Boolean @default(true)
  
  updatedAt       DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ───────────────── Licensing & Invoicing ─────────────────

enum PlanType {
  MONTHLY
  ANNUALLY
  LIFETIME
}

model LicensePlan {
  id            String   @id @default(cuid())
  name          String   @unique
  type          PlanType @default(MONTHLY)
  basePrice     Float    // Original Price
  salePrice     Float?   // Discounted Price
  isSaleActive  Boolean  @default(false)
  description   String?
  features      String[] // For display
  featureConfig Json     @default("{}") // For logic
  status        Status   @default(ACTIVE)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  mainMahallas  MainMahalla[]
  requests      RegistrationRequest[]
  invoices      Invoice[]
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id                    String         @id @default(cuid())
  invoiceNo             String         @unique
  amount                Float
  status                InvoiceStatus  @default(UNPAID)
  dueDate               DateTime
  paidAt                DateTime?
  
  // Relations
  licensePlanId         String
  licensePlan           LicensePlan    @relation(fields: [licensePlanId], references: [id])
  
  mainMahallaId         String?        // Link after approval
  registrationRequestId String?        // Link during registration phase
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Subscription {
  id              String       @id @default(cuid())
  mainMahallaId   String       @unique
  mainMahalla     MainMahalla  @relation(fields: [mainMahallaId], references: [id], onDelete: Cascade)
  licensePlanId   String
  status          Status       @default(ACTIVE)
  startDate       DateTime     @default(now())
  nextInvoiceDate DateTime
  lastInvoicedAt  DateTime?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum NoticeStatus {
  DRAFT
  PUBLISHED
}

model Notice {
  id                String             @id @default(cuid())
  title             String
  content           String             @db.Text
  coverImage        String?
  status            NoticeStatus       @default(DRAFT)
  
  // Authorization & Context
  authorId          String
  author            User               @relation(fields: [authorId], references: [id])
  mainMahallaId     String
  mainMahalla       MainMahalla        @relation(fields: [mainMahallaId], references: [id])
  
  // Targeting
  targetAllSub      Boolean            @default(false)
  targetSubMahallaIds String[]         @default([]) // Array of SubMahalla IDs
  
  subMahallaId      String?
  subMahalla        SubMahalla?        @relation(fields: [subMahallaId], references: [id])
  
  attachments       NoticeAttachment[]
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model NoticeAttachment {
  id        String   @id @default(cuid())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  url       String
  name      String
  type      String   // e.g., "image/jpeg", "application/pdf"
  createdAt DateTime @default(now())
}
